# Nylas v3 (https://dashboard-v3.nylas.com)
NYLAS_API_KEY=nyk_...
NYLAS_CLIENT_ID=your-nylas-client-id
# US region by default; use https://api.eu.nylas.com for EU apps
NYLAS_API_URI=https://api.us.nylas.com

# Anthropic (https://platform.claude.com)
ANTHROPIC_API_KEY=sk-ant-...

# OAuth callback — must be registered in the Nylas dashboard
CALLBACK_URI=http://localhost:3000/auth/callback
PORT=3000

# Your timezone for proposed meeting slots (IANA name)
USER_TIMEZONE=Asia/Tehran
